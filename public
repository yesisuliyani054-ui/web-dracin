<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KSANF</title>

<style>
*{box-sizing:border-box}
body{
margin:0;
background:#03050b;
color:white;
font-family:sans-serif;
}

/* TOPBAR */
.topbar{
position:fixed;
top:0;
width:100%;
display:flex;
justify-content:space-between;
padding:12px;
background:rgba(0,0,0,0.4);
backdrop-filter:blur(15px);
z-index:10;
}

.logo{
font-weight:bold;
color:#ff2e63;
letter-spacing:1px;
}

/* HERO */
.hero{
margin-top:50px;
height:240px;
position:relative;
}

.hero img{
width:100%;
height:100%;
object-fit:cover;
opacity:0.5;
}

.hero-content{
position:absolute;
bottom:20px;
left:15px;
}

.play-btn{
background:#ff2e63;
padding:10px 16px;
border-radius:12px;
margin-top:10px;
display:inline-block;
}

/* ROW */
.row{
margin-top:15px;
}

.row h3{
margin-left:12px;
font-size:14px;
opacity:0.8;
}

.scroll{
display:flex;
overflow-x:auto;
padding:10px;
gap:12px;
}

/* CARD */
.card{
min-width:150px;
border-radius:15px;
overflow:hidden;
position:relative;
transition:0.3s;
}

.card:hover{
transform:scale(1.07);
}

.card img{
width:100%;
height:200px;
object-fit:cover;
}

.overlay{
position:absolute;
bottom:0;
width:100%;
padding:10px;
background:linear-gradient(transparent,rgba(0,0,0,0.9));
font-size:12px;
}

/* PLAYER */
.player{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:black;
display:none;
z-index:99;
}

.player video{
width:100%;
height:100%;
}

.close{
position:absolute;
top:15px;
left:15px;
background:red;
padding:6px 10px;
border-radius:8px;
}

/* NAV */
.nav{
position:fixed;
bottom:0;
width:100%;
display:flex;
justify-content:space-around;
background:#05070d;
padding:10px;
border-top:1px solid rgba(255,255,255,0.1);
}

.nav div{
font-size:12px;
opacity:0.6;
cursor:pointer;
}

.nav .active{
opacity:1;
color:#ff2e63;
}
</style>
</head>

<body>

<div class="topbar">
<div class="logo">KSANF</div>
<div onclick="openLogin()">Login</div>
</div>

<!-- HERO -->
<div class="hero">
<img src="https://i.imgur.com/7b1ZQZL.jpg">
<div class="hero-content">
<h2>Drama Terpopuler</h2>
<div class="play-btn">▶ Tonton Sekarang</div>
</div>
</div>

<!-- ROW -->
<div class="row">
<h3>🔥 Trending</h3>
<div class="scroll" id="videos"></div>
</div>

<!-- PLAYER -->
<div id="player" class="player">
<div class="close" onclick="closePlayer()">✖</div>
<video id="vid" controls autoplay></video>
</div>

<!-- NAV -->
<div class="nav">
<div class="active">🏠</div>
<div>🔍</div>
<div>👑</div>
<div>👤</div>
</div>

<script>
function getDevice(){
return btoa(navigator.userAgent+screen.width)
}

/* LOAD VIDEO */
fetch("/videos")
.then(r=>r.json())
.then(data=>{
let html=""
data.forEach(v=>{
html+=`
<div class="card" onclick="play('${v.url}')">
<img src="${v.thumbnail}">
<div class="overlay">${v.title}</div>
</div>
`
})
document.getElementById("videos").innerHTML=html
})

function play(url){
document.getElementById("player").style.display="block"
document.getElementById("vid").src=url
}

function closePlayer(){
document.getElementById("player").style.display="none"
document.getElementById("vid").pause()
}
</script>

</body>
</html>
